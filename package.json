{
  "name": "studysmart",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:api": "json-server --watch db.json --port 3001 --cors",
    "dev:all": "concurrently -k \"npm run dev\" \"npm run dev:api\"",
    "build": "vite build",
    "preview": "vite preview --host",
    "start": "node scripts/start.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "json-server": "^0.17.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "vite": "^5.4.2"
  }
}


{
  "name": "studysmart",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:api": "json-server --watch db.json --port 3001 --cors",
    "dev:server": "node server/index.mjs",
    "dev:all": "concurrently -k \"npm run dev\" \"npm run dev:api\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview --host",
    "start": "node scripts/start.mjs"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "json-server": "^0.17.4",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.2",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "vite": "^5.4.2"
  }
}


# =============================================================================
# StudySmart — environment variables
# Copy to ".env" for local development. Never commit real API keys.
# =============================================================================

# --- OpenAI (required for note upload AI summary & "Explain this note" UI) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- JSON Server (mock DB) — URL with no trailing slash ----------------------------
# Local:  http://localhost:3001
# Hosted: https://your-json-server.onrender.com  (or Railway, Fly, etc.)
JSON_SERVER_URL=http://localhost:3001

# --- Node AI/API server (local only; on Vercel the api/ folder runs serverless) --
SERVER_PORT=3002

# =============================================================================
# Vite — embedded at *build* time (prefix VITE_)
# =============================================================================

# Public base URL for JSON Server (browser calls this). No trailing slash.
# Production: must be your deployed json-server HTTPS URL.
VITE_API_URL=http://localhost:3001

# AI + file-upload API base (browser calls this).
# Local dev:  /api  → Vite proxies to SERVER_PORT (see vite.config.js)
# Production: /api  → same origin on Vercel (Express app in api/index.mjs)
#             or full URL if the AI service is hosted elsewhere.
VITE_SERVER_API_URL=/api

# =============================================================================
# Vercel Dashboard → Project → Settings → Environment Variables
# =============================================================================
#
# Production / Preview — set at least:
#
#   OPENAI_API_KEY
#   OPENAI_MODEL          (optional; default gpt-4o-mini)
#   JSON_SERVER_URL       (required for note uploads saving to DB)
#   VITE_API_URL          (same value as JSON_SERVER_URL for production build)
#   VITE_SERVER_API_URL   (use /api if AI runs as Vercel serverless on same app)
#
# After adding VITE_* vars, trigger a new deployment so the SPA rebuilds.
#
